{
  "name": "mentoria-hightech-women",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/styles.css --minify",
    "build:html": "node scripts/build-html.mjs",
    "build:og": "node scripts/build-og.mjs",
    "build": "npm run build:css && npm run build:html && npm run build:og",
    "watch:css": "tailwindcss -i ./src/input.css -o ./dist/styles.css --watch"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "tailwindcss": "^3.4.17"
  }
}
